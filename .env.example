# Vitality Base runs with NO environment variables. Fork, deploy, done.
#
# OPTIONAL — cross-device sync + the Claude connector. Add your OWN free Supabase
# project's two PUBLIC keys (both are safe in the browser). From Supabase →
# Project Settings → API.
#   1. Create a free project at https://supabase.com
#   2. In its SQL editor run supabase/sync.sql (per-tile data) and, for the
#      connector, supabase/tiles.sql (tiles Claude builds for you)
#   3. Set these in Vercel → Settings → Environment Variables (and .env.local for
#      local dev), then redeploy
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL — the Claude connector password (app/api/mcp). Any long random string.
# Without it the connector is disabled (returns 503). Never commit the real value.
MCP_TOKEN=

# OPTIONAL — the Todoist tile (app/api/todoist). Your personal API token from
# Todoist → Settings → Integrations → Developer. Server-side only, never sent
# to the browser. Without it the Todoist tile shows "not connected".
TODOIST_TOKEN=

# OPTIONAL — the Claude chat widget (app/api/claude). A real Anthropic API key
# (console.anthropic.com → API Keys), billed per message. Server-side only,
# never sent to the browser. Without it the chat widget shows "not connected".
ANTHROPIC_API_KEY=
